{
  "name": "archmock",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@archmock/web",
    "dev:ws": "turbo run dev --filter=@archmock/ws-server",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @archmock/db migrate",
    "db:generate": "pnpm --filter @archmock/db generate",
    "db:seed": "pnpm --filter @archmock/db seed",
    "db:studio": "pnpm --filter @archmock/db studio",
    "db:reset": "pnpm --filter @archmock/db reset"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=22.0.0"
  }
}
